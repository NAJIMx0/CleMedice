<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cabinet.ui.controller.UsersController">
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text="< Retour" onAction="#handleBack" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
                <Label text="Gestion des Utilisateurs" textFill="WHITE" style="-fx-font-weight: bold;"><font><Font size="20"/></font></Label>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="userTable" prefHeight="400">
            <columns>
                <TableColumn text="ID" prefWidth="50"/>
                <TableColumn text="Nom" prefWidth="150"/>
                <TableColumn text="Email" prefWidth="200"/>
                <TableColumn text="Role" prefWidth="150"/>
                <TableColumn text="Actif" prefWidth="80"/>
                <TableColumn text="Actions" prefWidth="250"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox spacing="10" padding="10">
            <Button text="Ajouter" onAction="#handleAdd" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
            <Button text="Modifier" onAction="#handleEdit" style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
            <Button text="Reset Mot de passe" onAction="#handleResetPassword" style="-fx-background-color: #f39c12; -fx-text-fill: white;"/>
            <Button text="Supprimer" onAction="#handleDelete" style="-fx-background-color: #c0392b; -fx-text-fill: white;"/>
        </HBox>
    </bottom>
</BorderPane>
