<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cabinet.ui.controller.PatientsController">
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text="< Retour" onAction="#handleBack" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
                <Label text="Gestion des Patients" textFill="WHITE" fontSize="20" style="-fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <TextField fx:id="searchField" promptText="Rechercher..." prefWidth="250"/>
                <Button text="Rechercher" onAction="#handleSearch"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="patientTable" prefHeight="400">
            <columns>
                <TableColumn text="ID" prefWidth="50"/>
                <TableColumn text="Nom" prefWidth="150"/>
                <TableColumn text="Prenom" prefWidth="150"/>
                <TableColumn text="CIN" prefWidth="120"/>
                <TableColumn text="Telephone" prefWidth="120"/>
                <TableColumn text="Date Naissance" prefWidth="120"/>
                <TableColumn text="Adresse" prefWidth="200"/>
                <TableColumn text="Actions" prefWidth="200"/>
            </columns>
        </TableView>
    </center>
    <bottom>
        <HBox spacing="10" padding="10">
            <Button text="Ajouter Patient" onAction="#handleAdd" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
            <Button text="Modifier" onAction="#handleEdit" style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
            <Button text="Supprimer" onAction="#handleDelete" style="-fx-background-color: #c0392b; -fx-text-fill: white;"/>
        </HBox>
    </bottom>
</BorderPane>
