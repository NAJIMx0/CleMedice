<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cabinet.ui.controller.FinanceController">
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text="< Retour" onAction="#handleBack" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
                <Label text="Finance - Dakhal d Flous" textFill="WHITE" fontSize="20" style="-fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Exporter Excel" onAction="#handleExport" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="15" padding="20">
            <HBox spacing="20">
                <VBox style="-fx-background-color: #3498db; -fx-padding: 20; -fx-background-radius: 10; -fx-min-width: 200;">
                    <Label text="Total Mensuel" textFill="WHITE" fontSize="14"/>
                    <Label fx:id="totalMensuelLabel" text="0.00 MAD" textFill="WHITE" fontSize="24" style="-fx-font-weight: bold;"/>
                </VBox>
                <VBox style="-fx-background-color: #2ecc71; -fx-padding: 20; -fx-background-radius: 10; -fx-min-width: 200;">
                    <Label text="Total Annuel" textFill="WHITE" fontSize="14"/>
                    <Label fx:id="totalAnnuelLabel" text="0.00 MAD" textFill="WHITE" fontSize="24" style="-fx-font-weight: bold;"/>
                </VBox>
                <VBox spacing="5">
                    <Label text="Annee"/>
                    <TextField fx:id="anneeField"/>
                    <Label text="Mois"/>
                    <ComboBox fx:id="moisCombo"/>
                    <Button text="Actualiser" onAction="#handleRefresh"/>
                </VBox>
            </HBox>
            <TableView fx:id="paiementTable" prefHeight="300">
                <columns>
                    <TableColumn text="ID" prefWidth="50"/>
                    <TableColumn text="Patient" prefWidth="200"/>
                    <TableColumn text="Montant" prefWidth="120"/>
                    <TableColumn text="Date" prefWidth="120"/>
                    <TableColumn text="Mode" prefWidth="120"/>
                    <TableColumn text="Statut" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
