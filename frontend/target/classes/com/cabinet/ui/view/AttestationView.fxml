<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cabinet.ui.controller.AttestationController">
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text="< Retour" onAction="#handleBack" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
                <Label text="Attestation Medicale" textFill="WHITE" fontSize="20" style="-fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="15" padding="20">
            <HBox spacing="10">
                <Label text="Patient:" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="patientCombo" prefWidth="300" editable="true"/>
            </HBox>
            <Label text="Contenu de l'attestation"/>
            <TextArea fx:id="contenuField" prefRowCount="8"/>
            <HBox spacing="10">
                <Button text="Generer PDF" onAction="#handleGenerate" style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
                <Button text="Imprimer" onAction="#handlePrint" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
