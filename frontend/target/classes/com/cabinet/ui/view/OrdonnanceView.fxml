<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cabinet.ui.controller.OrdonnanceController">
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text="< Retour" onAction="#handleBack" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
                <Label text="Ordonnance" textFill="WHITE" fontSize="20" style="-fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="15" padding="20">
            <Label text="Cas Patient"/>
            <TextField fx:id="casPatientField"/>
            <Label text="Medicaments"/>
            <TableView fx:id="medicamentTable" prefHeight="200">
                <columns>
                    <TableColumn text="Medicament" prefWidth="200"/>
                    <TableColumn text="Dosage" prefWidth="100"/>
                    <TableColumn text="Duree" prefWidth="100"/>
                    <TableColumn text="Instructions" prefWidth="200"/>
                </columns>
            </TableView>
            <HBox spacing="10">
                <Button text="Ajouter Medicament" onAction="#handleAddMedicament"/>
                <Button text="Supprimer Medicament" onAction="#handleRemoveMedicament"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Enregistrer Ordonnance" onAction="#handleSave" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                <Button text="Generer PDF" onAction="#handlePrint" style="-fx-background-color: #2980b9; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
