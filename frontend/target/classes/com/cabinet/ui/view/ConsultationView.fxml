<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.cabinet.ui.controller.ConsultationController">
    <top>
        <VBox style="-fx-background-color: #2c3e50; -fx-padding: 10;">
            <HBox alignment="CENTER_LEFT" spacing="15">
                <Button text="< Retour" onAction="#handleBack" style="-fx-background-color: #34495e; -fx-text-fill: white;"/>
                <Label text="Consultation" textFill="WHITE" fontSize="20" style="-fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <VBox spacing="15" padding="20">
            <HBox spacing="10">
                <Label text="Patient:" style="-fx-font-weight: bold;"/>
                <Label fx:id="patientLabel"/>
                <Label text="Date:" style="-fx-font-weight: bold;" GridPane.columnIndex="2"/>
                <DatePicker fx:id="datePicker"/>
            </HBox>
            <Label text="Description"/>
            <TextArea fx:id="descriptionField" prefRowCount="4"/>
            <Label text="Observations"/>
            <TextArea fx:id="observationsField" prefRowCount="4"/>
            <Label text="Cas Patient"/>
            <TextField fx:id="casPatientField"/>
            <HBox spacing="10">
                <Button text="Enregistrer Consultation" onAction="#handleSave" style="-fx-background-color: #27ae60; -fx-text-fill: white;"/>
                <Button text="Generer Ordonnance" onAction="#handleOrdonnance" style="-fx-background-color: #e67e22; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
